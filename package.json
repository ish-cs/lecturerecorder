{
  "name": "lecturerecorder",
  "version": "1.0.0",
  "description": "Local-first lecture recording and note-taking app",
  "author": "LectureRecorder",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tiptap/extension-color": "^2.27.2",
    "@tiptap/extension-image": "^2.27.2",
    "@tiptap/extension-link": "^2.27.2",
    "@tiptap/extension-text-style": "^2.27.2",
    "@tiptap/extension-underline": "^2.27.2",
    "@tiptap/react": "^2.0.0",
    "@tiptap/starter-kit": "^2.0.0",
    "ffmpeg-static": "^5.3.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "uuid": "^9.0.0",
    "whisper-node": "^1.1.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.0.0",
    "tailwindcss": "^3.0.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "build": {
    "appId": "com.lecturerecorder.app",
    "productName": "LectureRecorder",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "models/",
        "to": "models/",
        "filter": [
          "*.bin"
        ]
      },
      {
        "from": "node_modules/whisper-node/lib/whisper.cpp/main",
        "to": "whisper-main"
      },
      {
        "from": "node_modules/whisper-node/lib/whisper.cpp/ggml-metal.metal",
        "to": "ggml-metal.metal"
      }
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**",
      "node_modules/whisper-node/lib/whisper.cpp/main"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.education",
      "icon": "build/icon.icns"
    },
    "dmg": {
      "title": "LectureRecorder"
    }
  }
}
